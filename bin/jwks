#!/usr/bin/env php
<?php

/**
 * jwks — manage the RSA signing keys behind the JWKS endpoint.
 * Run "bin/jwks help" for the list of commands.
 */

declare(strict_types=1);

use Jwks\Cli;
use Jwks\EnvFile;
use Jwks\KeyGenerator;
use Jwks\KeyStore;
use Jwks\RotationPolicy;

require dirname(__DIR__) . '/vendor/autoload.php';

/** @var list<string> $argv */

try {
    EnvFile::load(dirname(__DIR__) . '/.env');

    $keysDirectory = getenv('JWKS_KEYS_DIR');
    if (!is_string($keysDirectory) || $keysDirectory === '') {
        $keysDirectory = dirname(__DIR__) . '/working/keys';
    }

    exit(new Cli(
        new KeyStore($keysDirectory),
        RotationPolicy::fromEnvironment(),
        KeyGenerator::fromEnvironment(),
        STDOUT,
        STDERR,
    )->run($argv));
} catch (Throwable $exception) {
    fwrite(STDERR, 'Error: ' . $exception->getMessage() . "\n");
    exit(1);
}
