# JWKS service configuration — copy to .env and uncomment what you need.
# Real environment variables always win over values in this file.
# bin/jwks and the web endpoint both read .env from the project root.

# Where private keys are stored (default: working/keys at the project root)
#JWKS_KEYS_DIR=/var/www/jwks/working/keys

# Seconds a key lives after creation (default 2592000 = 30 days)
#JWKS_KEY_LIFETIME=2592000

# Seconds before expiry that a successor key is generated; also the purge
# grace period (default 604800 = 7 days)
#JWKS_ROTATION_BUFFER=604800

# Seconds a new key is published before it may sign (default 3600 = 1 hour)
#JWKS_TIME_UNTIL_USE=3600

# RSA key size in bits for new keys (default and minimum 2048)
#JWKS_KEY_BITS=2048
