{
    "name": "jwks/jwks",
    "description": "JWKS (JSON Web Key Set) service: generates RSA signing keys and serves the public key set at /.well-known/jwks.json",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-openssl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Jwks\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jwks\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "phpcs",
        "check": [
            "@test",
            "@stan",
            "@cs"
        ],
        "serve": "@php -S 127.0.0.1:8080 -t public public/index.php"
    },
    "scripts-descriptions": {
        "test": "Run the PHPUnit test suite",
        "stan": "Run phpstan static analysis at level 9",
        "cs": "Run phpcs coding-standard checks",
        "check": "Run tests, static analysis, and coding-standard checks",
        "serve": "Serve the JWKS endpoint with the built-in PHP web server"
    },
    "config": {
        "sort-packages": true
    }
}
